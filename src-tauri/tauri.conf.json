{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Schro",
  "version": "0.1.0",
  "identifier": "com.karr.schro",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "node scripts/patch_api_routes.js --static && IS_TAURI=true next build"
  },
  "app": {
    "windows": [
      {
        "title": "Schro",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
